@using EPiServer.Shell
@inject LocalizationService Loc
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = Loc.GetString("/editorpowertools/tools/cmsdoctor/title");
    string ActionPath(string path) => Paths.ToResource(typeof(UmageAI.Optimizely.EditorPowerTools.Menu.EditorPowertoolsMenuProvider), path);
}
@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
    <a href="@ActionPath("EditorPowertools/CmsDoctor")" class="active">CMS Doctor</a>
}
<div id="cms-doctor-root"></div>
@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(UmageAI.Optimizely.EditorPowerTools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/cms-doctor.js"))"></script>
}

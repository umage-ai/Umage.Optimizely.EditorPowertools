@using EPiServer.Shell
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = "Content Type Audit";
    string ActionPath(string path) => Paths.ToResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), path);
}

@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
    <a href="@ActionPath("EditorPowertools/ContentTypeAudit")" class="active">Content Type Audit</a>
}

<div class="ept-page-header">
    <h1>Content Type Audit</h1>
    <p>Overview of all content types, their usage, properties, and inheritance.</p>
</div>

<div id="audit-stats" class="ept-stats"></div>
<div id="audit-toolbar" class="ept-toolbar"></div>
<div id="audit-content"></div>

@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/content-type-audit.js"))"></script>
}

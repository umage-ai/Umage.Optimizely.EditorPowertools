@using EPiServer.Framework.Localization
@using EPiServer.Shell
@inject LocalizationService Loc
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = Loc.GetString("/editorpowertools/tools/about/title");
    var version = typeof(UmageAI.Optimizely.EditorPowerTools.Menu.EditorPowertoolsMenuProvider).Assembly.GetName().Version;
    var versionString = version != null ? $"v{version.Major}.{version.Minor}.{version.Build}" : "";
}

@section Styles {
<style>
.ept-about-hero {
    display: flex;
    align-items: flex-start;
    gap: var(--ept-space-xl, 32px);
    margin-bottom: var(--ept-space-lg, 24px);
}
.ept-about-hero__icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background: var(--ept-primary-light);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ept-primary);
}
.ept-about-hero__icon svg { width: 36px; height: 36px; }
.ept-about-hero__text h1 { margin-bottom: 8px; }
.ept-about-hero__badges { display: flex; gap: 8px; flex-wrap: wrap; }
.ept-about-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--ept-space-lg, 24px);
    margin-bottom: var(--ept-space-lg, 24px);
}
.ept-about-tools {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 12px;
}
.ept-about-tool {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--ept-text-secondary);
    padding: 6px 8px;
    border-radius: 6px;
    background: var(--ept-surface-hover);
}
.ept-about-tool svg { width: 14px; height: 14px; flex-shrink: 0; color: var(--ept-primary); }
.ept-about-made-by {
    background: #0f172a;
    border-radius: 12px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    gap: 40px;
    margin-bottom: var(--ept-space-lg, 24px);
    color: #e2e8f0;
}
.ept-about-made-by__logo {
    flex-shrink: 0;
    width: 180px;
}
.ept-about-made-by__logo svg { width: 100%; height: auto; }
.ept-about-made-by__divider {
    width: 1px;
    height: 80px;
    background: #334155;
    flex-shrink: 0;
}
.ept-about-made-by__text { flex: 1; }
.ept-about-made-by__text h2 {
    font-size: 18px;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 8px;
}
.ept-about-made-by__text p {
    font-size: 14px;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 16px;
}
.ept-about-made-by__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #3b82f6;
    color: #fff;
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
}
.ept-about-made-by__cta:hover { background: #2563eb; color: #fff; }
</style>
}

<div class="ept-about-hero">
    <div class="ept-about-hero__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
    </div>
    <div class="ept-about-hero__text">
        <h1>@Loc.GetString("/editorpowertools/tools/about/title")</h1>
        <div class="ept-about-hero__badges">
            @if (!string.IsNullOrEmpty(versionString))
            {
                <span class="ept-badge ept-badge--primary">@versionString</span>
            }
            <span class="ept-badge ept-badge--success">Open Source</span>
            <span class="ept-badge ept-badge--default">Optimizely CMS @(System.Environment.Version.Major >= 10 ? "13" : "12")</span>
            <span class="ept-badge ept-badge--default">.NET @System.Environment.Version.Major</span>
            <a href="https://github.com/UmageAI/EditorPowerTools" target="_blank" rel="noopener" class="ept-badge ept-badge--default" style="text-decoration:none;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:12px;height:12px;vertical-align:middle;margin-right:3px"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub
            </a>
        </div>
    </div>
</div>

<div class="ept-about-cards">
    <div class="ept-card">
        <div class="ept-card__header">
            <div class="ept-card__title">@Loc.GetString("/editorpowertools/tools/about/whatis_title")</div>
        </div>
        <div class="ept-card__body">
            <p style="font-size:14px;line-height:1.7;color:var(--ept-text-secondary);margin-bottom:16px;">
                @Loc.GetString("/editorpowertools/tools/about/whatis_body")
            </p>
            <p style="font-size:14px;line-height:1.7;color:var(--ept-text-secondary);">
                @Loc.GetString("/editorpowertools/tools/about/whatis_install")
                <code style="background:var(--ept-surface-hover);padding:2px 6px;border-radius:4px;font-size:12px;">UmageAI.Optimizely.EditorPowerTools</code>
            </p>
        </div>
    </div>

    <div class="ept-card">
        <div class="ept-card__header">
            <div class="ept-card__title">@Loc.GetString("/editorpowertools/tools/about/tools_title")</div>
        </div>
        <div class="ept-card__body">
            <div class="ept-about-tools">
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                    Content Statistics
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Activity Timeline
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Bulk Property Editor
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                    Content Audit
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    CMS Doctor
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Security Audit
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    Link Checker
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><circle cx="19" cy="11" r="2"/></svg>
                    Active Editors
                </div>
                <div class="ept-about-tool">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    Content Importer
                </div>
            </div>
        </div>
    </div>
</div>


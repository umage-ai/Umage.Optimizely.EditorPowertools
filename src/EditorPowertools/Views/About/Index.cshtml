        <h2>@Loc.GetString("/editorpowertools/tools/about/madeby_title")</h2>
        <p>@Loc.GetString("/editorpowertools/tools/about/madeby_body")</p>
        <a href="https://umage.ai/?utm_source=powertools" target="_blank" rel="noopener" class="ept-about-made-by__cta">

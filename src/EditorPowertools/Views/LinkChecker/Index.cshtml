@using EPiServer.Shell
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = "Link Checker";
    string ActionPath(string path) => Paths.ToResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), path);
}

@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
}

<div class="ept-page-header">
    <h1>Link Checker</h1>
    <p>Find and fix broken internal and external links across your content.</p>
</div>

<div id="linkchecker-stats" class="ept-stats"></div>
<div id="linkchecker-toolbar" class="ept-toolbar"></div>
<div id="linkchecker-content"></div>

@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/link-checker.js"))"></script>
}

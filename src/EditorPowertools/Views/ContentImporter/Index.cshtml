@using EPiServer.Shell
@inject LocalizationService Loc
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = Loc.GetString("/editorpowertools/tools/contentimporter/title");
    string ActionPath(string path) => Paths.ToResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), path);
}
@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
    <a href="@ActionPath("EditorPowertools/ContentImporter")" class="active">Content Importer</a>
}
<div class="ept-page-header">
    <h1>@Loc.GetString("/editorpowertools/tools/contentimporter/title") <button class="ept-help-btn" data-ept-help="contentimporter" title='@Loc.GetString("/editorpowertools/ui/help/helpbtn")'>?</button></h1>
    <p>@Loc.GetString("/editorpowertools/tools/contentimporter/description")</p>
</div>
<div id="content-importer-root"></div>
@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/content-importer.js"))"></script>
}

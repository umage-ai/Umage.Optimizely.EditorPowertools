@using EPiServer.Shell
@using UmageAI.Optimizely.EditorPowerTools.Abstractions
@inject LocalizationService Loc
@inject IEnumerable<IPowertoolDescriptor> Tools
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = Loc.GetString("/editorpowertools/tools/overview/title");

    // Resolve localized strings — descriptor titles/descriptions are stored
    // as language-key paths so the same descriptor renders in any culture.
    string Resolve(string keyOrLiteral) =>
        keyOrLiteral.StartsWith('/') ? Loc.GetString(keyOrLiteral) : keyOrLiteral;

    var groupOrder = new[]
    {
        PowertoolGroups.ContentEditorial,
        PowertoolGroups.AuditsAnalysis,
        PowertoolGroups.Forms,
        PowertoolGroups.ConfigurationAdmin
    };

    var available = Tools
        .Where(t => t.IsAvailable(Context))
        .OrderBy(t => Array.IndexOf(groupOrder, t.Group) is var idx && idx < 0 ? int.MaxValue : idx)
        .ThenBy(t => t.SortIndex)
        .ToList();

    string GroupLabel(string g) => g switch
    {
        PowertoolGroups.ContentEditorial   => Loc.GetString("/editorpowertools/tools/overview/group/contenteditorial"),
        PowertoolGroups.AuditsAnalysis     => Loc.GetString("/editorpowertools/tools/overview/group/auditsanalysis"),
        PowertoolGroups.Forms              => Loc.GetString("/editorpowertools/tools/overview/group/forms"),
        PowertoolGroups.ConfigurationAdmin => Loc.GetString("/editorpowertools/tools/overview/group/configurationadmin"),
        _ => g
    };
}

@section NavItems {
}

<div class="ept-page-header">
    <h1>@Loc.GetString("/editorpowertools/menu/title")</h1>
    <p>@Loc.GetString("/editorpowertools/tools/overview/description")</p>
</div>

@foreach (var group in available.GroupBy(t => t.Group))
{
    <h2 class="ept-tool-group-heading">@GroupLabel(group.Key)</h2>
    <div class="ept-tool-grid">
        @foreach (var t in group)
        {
            <a href="@t.Url" class="ept-tool-card" data-tool-id="@t.Id">
                <svg class="ept-tool-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    @Html.Raw(t.IconSvgPath)
                </svg>
                <div class="ept-tool-card__title">@Resolve(t.Title)</div>
                <div class="ept-tool-card__desc">@Resolve(t.Description)</div>
            </a>
        }
    </div>
}

@using EPiServer.Shell
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = "Activity Timeline";
    string ActionPath(string path) => Paths.ToResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), path);
}

@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
}

<div class="ept-page-header">
    <h1>Activity Timeline</h1>
    <p>Track all editorial activities across the site.</p>
</div>

<div id="timeline-stats" class="ept-stats"></div>
<div id="timeline-toolbar" class="ept-toolbar"></div>
<div id="timeline-content"></div>

@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/activity-timeline.js"))"></script>
}

@using EPiServer.Shell
@inject LocalizationService Loc
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = Loc.GetString("/editorpowertools/tools/audiencemanager/title");
    string ActionPath(string path) => Paths.ToResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), path);
}

@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
}

<div class="ept-page-header">
    <h1>@Loc.GetString("/editorpowertools/tools/audiencemanager/title")</h1>
    <p>@Loc.GetString("/editorpowertools/tools/audiencemanager/description")</p>
</div>

<div id="audience-stats" class="ept-stats"></div>
<div id="audience-toolbar" class="ept-toolbar"></div>
<div id="audience-content"></div>

@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/audience-manager.js"))"></script>
}

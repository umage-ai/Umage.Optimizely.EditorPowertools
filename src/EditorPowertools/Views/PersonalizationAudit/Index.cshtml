@using EPiServer.Shell
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = "Personalization Audit";
    string ActionPath(string path) => Paths.ToResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), path);
}

@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
}

<div class="ept-page-header">
    <h1>Personalization Audit</h1>
    <p>Overview of where audiences and personalization are used across the site.</p>
</div>

<div id="personalization-stats" class="ept-stats"></div>
<div id="personalization-toolbar" class="ept-toolbar"></div>
<div id="personalization-content"></div>

@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(EditorPowertools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/personalization-audit.js"))"></script>
}

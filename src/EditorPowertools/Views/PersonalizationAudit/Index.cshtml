@using EPiServer.Shell
@inject LocalizationService Loc
@{
    Layout = "/Views/Shared/_PowertoolsLayout.cshtml";
    ViewData["Title"] = Loc.GetString("/editorpowertools/tools/personalizationaudit/title");
    string ActionPath(string path) => Paths.ToResource(typeof(UmageAI.Optimizely.EditorPowerTools.Menu.EditorPowertoolsMenuProvider), path);
}

@section NavItems {
    <a href="@ActionPath("EditorPowertools/Overview")">Overview</a>
}

<div class="ept-page-header">
    <h1>@Loc.GetString("/editorpowertools/tools/personalizationaudit/title") <button class="ept-help-btn" data-ept-help="personalizationaudit" title='@Loc.GetString("/editorpowertools/ui/help/helpbtn")'>?</button></h1>
    <p>@Loc.GetString("/editorpowertools/tools/personalizationaudit/description")</p>
</div>

<div id="personalization-stats" class="ept-stats"></div>
<div id="personalization-toolbar" class="ept-toolbar"></div>
<div id="personalization-content"></div>

@section Scripts {
    <script src="@(EPiServer.Shell.Paths.ToClientResource(typeof(UmageAI.Optimizely.EditorPowerTools.Menu.EditorPowertoolsMenuProvider), "ClientResources/js/personalization-audit.js"))"></script>
}

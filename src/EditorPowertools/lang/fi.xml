      <!-- Komponentit (CMS-resurssipaneelin widgetit) -->
      <components>
        <contentdetails>
          <title>Power Sisältötiedot</title>
          <description>Yksityiskohtaiset tiedot valitusta sisältökohteesta - ominaisuudet, viittaukset, versiot.</description>
        </contentdetails>
        <activeeditors>
          <title>Aktiiviset muokkaajat</title>
          <description>Näe kuka muu muokkaa tätä sisältöä ja tee yhteistyötä tiimisi kanssa.</description>
        </activeeditors>
      </components>

      <!-- Työkalujen otsikot ja kuvaukset -->
      <tools>
        <contenttypeaudit>
          <title>Sisältötyyppien tarkastus</title>
          <description>Yleiskatsaus kaikkiin sisältötyyppeihin, niiden käyttöön, ominaisuuksiin ja periytymiseen.</description>
        </contenttypeaudit>
        <personalizationaudit>
          <title>Personoinnin tarkastus</title>
          <description>Etsi ja tarkasta vierailijaryhmien käyttö sisällössä, käyttöoikeuksissa ja ominaisuuksissa.</description>
        </personalizationaudit>
        <audiencemanager>
          <title>Kohderyhmien hallinta</title>
          <description>Hallitse ja tarkista vierailijaryhmiä ja kohderyhmäsegmenttejä.</description>
        </audiencemanager>
        <contenttyperecommendations>
          <title>Sisältötyyppien suositukset</title>
          <description>Saa suosituksia sisältötyyppien parantamiseen ja yhdistämiseen.</description>
        </contenttyperecommendations>
        <bulkpropertyeditor>
          <title>Joukko-ominaisuusmuokkain</title>
          <description>Muokkaa ominaisuuksia useissa sisältökohteissa kerralla.</description>
        </bulkpropertyeditor>
        <scheduledjobsgantt>
          <title>Ajastetut tehtävät Gantt</title>
          <description>Visualisoi ajastettujen tehtävien suoritus Gantt-kaaviona.</description>
        </scheduledjobsgantt>
        <activitytimeline>
          <title>Toiminnan aikajana</title>
          <description>Näytä aikajana sisältömuutoksista ja toimituksellisesta toiminnasta.</description>
        </activitytimeline>
        <contentimporter>
          <title>Sisällön tuonti</title>
          <description>Tuo sisältöä CSV-, JSON- tai Excel-tiedostoista.</description>
        </contentimporter>
        <cmsdoctor>
          <title>CMS-tohtori</title>
          <description>Terveystarkastukset ja diagnostiikka CMS-asennuksellesi.</description>
        </cmsdoctor>
        <contentaudit>
          <title>Sisällön auditointi</title>
          <description>Tarkista sisällön laatu, kattavuus ja parhaat käytännöt.</description>
        </contentaudit>
        <linkchecker>
          <title>Linkkien tarkistus</title>
          <description>Etsi ja raportoi rikkinäiset linkit sivustollasi.</description>
        </linkchecker>
        <activeeditors>
          <title>Aktiiviset muokkaajat</title>
          <description>Näe kuka muokkaa sisältöä juuri nyt ja tee yhteistyötä reaaliajassa.</description>
        </activeeditors>
        <managechildren>
          <title>Hallitse alasivuja</title>
          <description>Joukkohallitse alasivuja: lajittele, julkaise, peru julkaisu, siirrä ja poista.</description>
        </managechildren>
        <overview>
          <title>Yleiskatsaus</title>
          <description>Kojelaudan yleiskatsaus kaikista Editor Powertools -ominaisuuksista.</description>
        </overview>
        <visitorgrouptester>
          <title>Vierailijaryhmätestaus</title>
          <description>Kelluva työkalupalkki vierailijaryhmäjäsenyyden simulointiin ja muokattavien sisältöelementtien tarkasteluun.</description>
        </visitorgrouptester>
        <contentstatistics>
          <title>Sisältötilastot</title>
          <description>Visuaalinen kojelauta kaavioilla, jotka näyttävät sisällön jakautumisen, luontitrendit, vanhentumisen ja muokkaajien aktiivisuuden.</description>
        </contentstatistics>
        <languageaudit>
          <title>Kielitarkastus</title>
          <description>Analysoi kielikattavuus, etsi puuttuvat käännökset ja hallitse käännösprioriteetit.</description>
        </languageaudit>
        <linkaudit>
          <title>Linkkitarkastus</title>
          <description>Etsi ja korjaa rikkinäiset sisäiset ja ulkoiset linkit sisällössäsi.</description>
        </linkaudit>
        <securityaudit>
          <title>Tietoturvatarkastus</title>
          <description>Analysoi sisällön käyttöoikeudet, etsi liian väljät käyttöoikeudet ja selvitä kuka pääsee mihinkin.</description>
        </securityaudit>
      </tools>

      <!-- Ajastettu tehtävä -->
      <jobs>
        <contentanalysis>
          <displayname>[EditorPowertools] Sisältöanalyysi</displayname>
          <description>Yhdistetty tehtävä, joka käy läpi kaiken sisällön kerran ja suorittaa kaikki rekisteröidyt analysaattorit (sisältötyyppistatistiikka, personointi, linkkien tarkistus jne.).</description>
          <noanalyzers>Analysaattoreita ei ole rekisteröity.</noanalyzers>
          <initializing>Alustetaan {0} analysaattoria...</initializing>
          <analyzing>Analysoidaan {0} sisältökohdetta {1} analysaattorilla...</analyzing>
          <stopped>Pysäytetty kohdan {0}/{1} jälkeen.</stopped>
          <processing>Käsitelty {0}/{1} sisältökohdetta...</processing>
          <completing>Viimeistellään analysaattoreita...</completing>
          <completed>Valmis. Analysoitu {0} sisältökohdetta {1} analysaattorilla ({2}).</completed>
        </contentanalysis>
      </jobs>

      <!-- CMS-tohtori terveystarkastukset -->
      <cmsdoctor>
        <runjobfirst>Suorita ajastettu tehtävä '[EditorPowertools] Sisältöanalyysi' ensin.</runjobfirst>
        <checks>
          <memorycheck>
            <name>Muistin käyttö</name>
            <description>Raportoi sovelluksen nykyisen muistinkäytön.</description>
            <group>Ympäristö</group>
            <biton64>Toimii 32-bittisenä 64-bittisessä käyttöjärjestelmässä. Muisti: {0} MB.</biton64>
            <highmemory>Korkea muistinkäyttö: {0} MB.</highmemory>
            <ok>Muisti: {0} MB working set.</ok>
            <details>Working set: {0} MB, GC heap: {1} MB, 64-bittinen prosessi: {2}, 64-bittinen OS: {3}</details>
          </memorycheck>
          <versioninfocheck>
            <name>CMS-versio</name>
            <description>Raportoi nykyisen Optimizely CMS -version.</description>
            <group>Ympäristö</group>
            <ok>Optimizely CMS {0}</ok>
            <details>EPiServer assembly-versio: {0}. .NET {1}</details>
            <unknown>Tuntematon</unknown>
            <couldnotdetermine>CMS-versiota ei voitu määrittää.</couldnotdetermine>
          </versioninfocheck>
          <contenttypecheck>
            <name>Sisältötyyppien määrä</name>
            <description>Tarkistaa, onko sisältötyyppien määrä kohtuullisissa rajoissa.</description>
            <group>Sisältö</group>
            <toomanypagetypes>Liian monta sivutyyppiä ({0}). Muokkaajien voi olla vaikea löytää oikeaa.</toomanypagetypes>
            <toomanyblocktypes>Liian monta lohkotyyppiä ({0}). Harkitse yhdistämistä.</toomanyblocktypes>
            <toofewpagetypes>Vain {0} sivutyyppi(ä). Sisällöstä voi puuttua rakenne.</toofewpagetypes>
            <ok>{0} sisältötyyppiä ({1} sivua, {2} lohkoa, {3} mediaa)</ok>
            <details>Sivutyypit: {0}, Lohkotyypit: {1}, Mediatyypit: {2}, Yhteensä: {3}</details>
          </contenttypecheck>
          <orphanedpropertycheck>
            <name>Orvot ominaisuudet</name>
            <description>Etsii ominaisuuksia, jotka on määritelty tietokannassa mutta ei koodissa.</description>
            <group>Sisältö</group>
            <found>{0} orvoksi jäänyttä ominaisuutta löydetty tietokannasta, joita ei ole määritelty koodissa.</found>
            <ok>Orvoksi jääneitä ominaisuuksia ei löytynyt.</ok>
            <examples>Esimerkit: {0}</examples>
            <andmore>(ja {0} lisää)</andmore>
          </orphanedpropertycheck>
          <scheduledjobscheck>
            <name>Ajastettujen tehtävien terveys</name>
            <description>Tarkistaa epäonnistuneet tai pitkäkestoiset ajastetut tehtävät.</description>
            <group>Ympäristö</group>
            <failed>{0} ajastettu(a) tehtävä(ä) sisältää virheitä.</failed>
            <neverrun>{0} käytössä olevaa tehtävää ei ole koskaan suoritettu.</neverrun>
            <ok>Kaikki {0} käytössä olevaa tehtävää ovat kunnossa.</ok>
            <failedlabel>Epäonnistuneet: {0}</failedlabel>
            <neverrunlabel>Ei koskaan suoritettu: {0}</neverrunlabel>
          </scheduledjobscheck>
          <draftcontentcheck>
            <name>Vanhentuneet luonnokset</name>
            <description>Tarkistaa luonnossisältöä, jota ei ole koskaan julkaistu tai jossa on vanhoja julkaisemattomia muutoksia.</description>
            <group>Sisältö</group>
            <ok>Vanhentuneita luonnoksia ei löytynyt.</ok>
            <warning>{0} vanhentunutta sisältökohdetta löydetty. Harkitse tarkistamista ja siivoamista.</warning>
            <minor>{0} vanhentunutta kohdetta löydetty (vähäinen).</minor>
            <details>Ei koskaan julkaistu: {0}, Vanhentuneet luonnokset (>3 kuukautta): {1}</details>
          </draftcontentcheck>
          <brokenlinkscheck>
            <name>Rikkinäiset linkit</name>
            <description>Raportoi Linkkien tarkistus -työkalun löytämät rikkinäiset linkit.</description>
            <group>Sisältö</group>
            <nodata>Linkkitietoja ei saatavilla. Suorita ajastettu tehtävä Sisältöanalyysi ensin.</nodata>
            <nodatadetails>Linkkien tarkistuksen analysaattori täyttää nämä tiedot ajastetun tehtävän aikana.</nodatadetails>
            <allhealthy>Kaikki {0} linkkiä ovat kunnossa.</allhealthy>
            <fault>{0} rikkinäistä linkkiä löydetty {1} linkistä yhteensä.</fault>
            <warning>{0} rikkinäistä linkkiä löydetty.</warning>
            <details>Linkkejä yhteensä: {0}, Rikkinäisiä: {1}. 404:t: {2}, 5xx: {3}, Aikakatkaisut: {4}</details>
            <notavailable>Linkkien tarkistuksen tiedot eivät ole vielä saatavilla.</notavailable>
          </brokenlinkscheck>
          <missingalttextcheck>
            <name>Puuttuva alt-teksti</name>
            <description>Tarkistaa kuvat, joista puuttuu alt-teksti (saavutettavuus- ja SEO-ongelma).</description>
            <group>Sisältö</group>
            <noimages>Kuvia ei löytynyt.</noimages>
            <badpractice>{0} kuvaa ilman alt-tekstiä ({1}%).</badpractice>
            <warning>{0} kuvaa ilman alt-tekstiä.</warning>
            <ok>Kaikissa kuvissa on alt-teksti.</ok>
            <details>{0}/{1} kuvasta ({2}%) puuttuu alt-teksti. Viimeksi analysoitu: {3}</details>
          </missingalttextcheck>
          <unusedcontentcheck>
            <name>Käyttämätön sisältö</name>
            <description>Tarkistaa lohkot ja mediat, joihin ei viitata mistään (mahdollisia orpoja).</description>
            <group>Sisältö</group>
            <noblocks>Lohkoja tai mediaa ei löytynyt.</noblocks>
            <warning>{0} viittaamatonta kohdetta ({1}%). Harkitse siivoamista.</warning>
            <minor>{0} viittaamatonta kohdetta ({1}%, vähäinen).</minor>
            <ok>Kaikkiin lohkoihin ja medioihin viitataan.</ok>
            <details>{0}/{1} lohkosta/mediasta ({2}%) on viittaamattomia. Viimeksi analysoitu: {3}</details>
          </unusedcontentcheck>
          <everyonepublishrightscheck>
            <name>Kaikilla on julkaisuoikeudet</name>
            <description>Raportoi sisällön, jossa "Kaikki"-roolilla on julkaisu- tai korkeammat oikeudet.</description>
            <group>Tietoturva</group>
            <nodata>Tietoturvatarkastuksen tietoja ei saatavilla. Suorita ajastettu tehtävä Sisältöanalyysi ensin.</nodata>
            <nodatadetails>Tietoturvatarkastuksen analysaattori täyttää nämä tiedot ajastetun tehtävän aikana.</nodatadetails>
            <ok>Mikään sisältö ei anna "Kaikki"-roolille julkaisuoikeuksia.</ok>
            <warning>{0} sisältökohdetta antaa "Kaikki"-roolille julkaisu- tai korkeammat oikeudet.</warning>
            <notavailable>Tietoturvatarkastuksen tiedot eivät ole vielä saatavilla.</notavailable>
          </everyonepublishrightscheck>
          <unrestrictedcontentcheck>
            <name>Rajoittamaton sisältö</name>
            <description>Raportoi sivut, joilla ei ole käyttöoikeusrajoituksia.</description>
            <group>Tietoturva</group>
            <nodata>Tietoturvatarkastuksen tietoja ei saatavilla. Suorita ajastettu tehtävä Sisältöanalyysi ensin.</nodata>
            <nodatadetails>Tietoturvatarkastuksen analysaattori täyttää nämä tiedot ajastetun tehtävän aikana.</nodatadetails>
            <ok>Kaikilla sivuilla on käyttöoikeusrajoitukset.</ok>
            <badpractice>{0} sivulla ei ole käyttöoikeusrajoituksia (täysin avoimia).</badpractice>
            <notavailable>Tietoturvatarkastuksen tiedot eivät ole vielä saatavilla.</notavailable>
          </unrestrictedcontentcheck>
          <inconsistentinheritancecheck>
            <name>Epäjohdonmukainen oikeuksien periytyminen</name>
            <description>Raportoi sisällön, joka on sallivampi kuin sen yläkohde, mikä voi viitata tahattomiin ACL-muutoksiin.</description>
            <group>Tietoturva</group>
            <nodata>Tietoturvatarkastuksen tietoja ei saatavilla. Suorita ajastettu tehtävä Sisältöanalyysi ensin.</nodata>
            <nodatadetails>Tietoturvatarkastuksen analysaattori täyttää nämä tiedot ajastetun tehtävän aikana.</nodatadetails>
            <ok>Oikeuksien periytymisessä ei löytynyt epäjohdonmukaisuuksia.</ok>
            <warning>{0} sisältökohdetta on sallivampi kuin sen yläkohde.</warning>
            <notavailable>Tietoturvatarkastuksen tiedot eivät ole vielä saatavilla.</notavailable>
          </inconsistentinheritancecheck>
        </checks>
        <groups>
          <environment>Ympäristö</environment>
          <content>Sisältö</content>
          <security>Tietoturva</security>
        </groups>
        <tags>
          <performance>Suorituskyky</performance>

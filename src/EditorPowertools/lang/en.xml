      <!-- CMS Doctor health checks -->
      <cmsdoctor>
        <runjobfirst>Run the '[EditorPowertools] Content Analysis' scheduled job first.</runjobfirst>
        <checks>
          <memorycheck>
            <name>Memory Usage</name>
            <description>Reports current memory usage of the application.</description>
            <group>Environment</group>
            <biton64>Running as 32-bit on 64-bit OS. Memory: {0} MB.</biton64>
            <highmemory>High memory usage: {0} MB.</highmemory>
            <ok>Memory: {0} MB working set.</ok>
            <details>Working set: {0} MB, GC heap: {1} MB, 64-bit process: {2}, 64-bit OS: {3}</details>
          </memorycheck>
          <versioninfocheck>
            <name>CMS Version</name>
            <description>Reports the current Optimizely CMS version.</description>
            <group>Environment</group>
            <ok>Optimizely CMS {0}</ok>
            <details>EPiServer assembly version: {0}. .NET {1}</details>
            <unknown>Unknown</unknown>
            <couldnotdetermine>Could not determine CMS version.</couldnotdetermine>
          </versioninfocheck>
          <contenttypecheck>
            <name>Content Type Count</name>
            <description>Checks if the number of content types is within reasonable limits.</description>
            <group>Content</group>
            <toomanypagetypes>Too many page types ({0}). Editors may struggle to find the right one.</toomanypagetypes>
            <toomanyblocktypes>Too many block types ({0}). Consider consolidating.</toomanyblocktypes>
            <toofewpagetypes>Only {0} page type(s). Content may lack structure.</toofewpagetypes>
            <ok>{0} content types ({1} pages, {2} blocks, {3} media)</ok>
            <details>Page types: {0}, Block types: {1}, Media types: {2}, Total: {3}</details>
          </contenttypecheck>
          <orphanedpropertycheck>
            <name>Orphaned Properties</name>
            <description>Finds properties defined in the database but not in code.</description>
            <group>Content</group>
            <found>{0} orphaned properties found in the database that are not defined in code.</found>
            <ok>No orphaned properties found.</ok>
            <examples>Examples: {0}</examples>
            <andmore>(and {0} more)</andmore>
          </orphanedpropertycheck>
          <scheduledjobscheck>
            <name>Scheduled Jobs Health</name>
            <description>Checks for failed or long-running scheduled jobs.</description>
            <group>Environment</group>
            <failed>{0} scheduled job(s) have errors.</failed>
            <neverrun>{0} enabled job(s) have never run.</neverrun>
            <ok>All {0} enabled jobs are healthy.</ok>
            <failedlabel>Failed: {0}</failedlabel>
            <neverrunlabel>Never run: {0}</neverrunlabel>
          </scheduledjobscheck>
          <draftcontentcheck>
            <name>Stale Drafts</name>
            <description>Checks for draft content that has never been published or has old unpublished changes.</description>
            <group>Content</group>
            <ok>No stale drafts found.</ok>
            <warning>{0} stale content items found. Consider reviewing and cleaning up.</warning>
            <minor>{0} stale items found (minor).</minor>
            <details>Never published: {0}, Stale drafts (>3 months): {1}</details>
          </draftcontentcheck>
          <brokenlinkscheck>
            <name>Broken Links</name>
            <description>Reports broken links found by the Link Checker tool.</description>
            <group>Content</group>
            <nodata>No link data available. Run the Content Analysis scheduled job first.</nodata>
            <nodatadetails>The Link Checker analyzer populates this data during the scheduled job.</nodatadetails>
            <allhealthy>All {0} links are healthy.</allhealthy>
            <fault>{0} broken links found across {1} total links.</fault>
            <warning>{0} broken links found.</warning>
            <details>Total links: {0}, Broken: {1}. 404s: {2}, 5xx: {3}, Timeouts: {4}</details>
            <notavailable>Link checker data not available yet.</notavailable>
          </brokenlinkscheck>
          <missingalttextcheck>
            <name>Missing Alt Text</name>
            <description>Checks for images missing alt text (accessibility and SEO issue).</description>
            <group>Content</group>
            <noimages>No images found.</noimages>
            <badpractice>{0} images missing alt text ({1}%).</badpractice>
            <warning>{0} images missing alt text.</warning>
            <ok>All images have alt text.</ok>
            <details>{0} of {1} images ({2}%) have no alt text. Last analyzed: {3}</details>
          </missingalttextcheck>
          <unusedcontentcheck>
            <name>Unused Content</name>
            <description>Checks for blocks and media not referenced by anything (potential orphans).</description>
            <group>Content</group>
            <noblocks>No blocks or media found.</noblocks>
            <warning>{0} unreferenced items ({1}%). Consider cleanup.</warning>
            <minor>{0} unreferenced items ({1}%, minor).</minor>
            <ok>All blocks and media are referenced.</ok>
            <details>{0} of {1} blocks/media ({2}%) are unreferenced. Last analyzed: {3}</details>
          </unusedcontentcheck>
          <everyonepublishrightscheck>
            <name>Everyone Publish Rights</name>
            <description>Reports content where the "Everyone" role has Publish or higher access.</description>
            <group>Security</group>
            <nodata>No security audit data available. Run the Content Analysis scheduled job first.</nodata>
            <nodatadetails>The Security Audit analyzer populates this data during the scheduled job.</nodatadetails>
            <ok>No content grants Publish to the "Everyone" role.</ok>
            <warning>{0} content item(s) grant Publish or higher to the "Everyone" role.</warning>
            <notavailable>Security audit data not available yet.</notavailable>
          </everyonepublishrightscheck>
          <unrestrictedcontentcheck>
            <name>Unrestricted Content</name>
            <description>Reports pages with no access restrictions set.</description>
            <group>Security</group>
            <nodata>No security audit data available. Run the Content Analysis scheduled job first.</nodata>
            <nodatadetails>The Security Audit analyzer populates this data during the scheduled job.</nodatadetails>
            <ok>All pages have access restrictions.</ok>
            <badpractice>{0} page(s) have no access restrictions (wide open).</badpractice>
            <notavailable>Security audit data not available yet.</notavailable>
          </unrestrictedcontentcheck>
          <inconsistentinheritancecheck>
            <name>Inconsistent Permission Inheritance</name>
            <description>Reports content that is more permissive than its parent, which may indicate accidental ACL changes.</description>
            <group>Security</group>
            <nodata>No security audit data available. Run the Content Analysis scheduled job first.</nodata>
            <nodatadetails>The Security Audit analyzer populates this data during the scheduled job.</nodatadetails>
            <ok>No permission inheritance inconsistencies found.</ok>
            <warning>{0} content item(s) are more permissive than their parent.</warning>
            <notavailable>Security audit data not available yet.</notavailable>
          </inconsistentinheritancecheck>
        </checks>

      <!-- Components (CMS assets panel widgets) -->
      <components>
        <contentdetails>
          <title>Power Content Details</title>
          <description>Detailed information about the selected content item - properties, references, versions.</description>
        </contentdetails>
        <activeeditors>
          <title>Active Editors</title>
          <description>See who else is editing this content and collaborate with your team.</description>
        </activeeditors>
      </components>

      <!-- Tool titles and descriptions -->
      <tools>
        <contenttypeaudit>
          <title>Content Type Audit</title>
          <description>Overview of all content types, their usage, properties, and inheritance.</description>
        </contenttypeaudit>
        <personalizationaudit>
          <title>Personalization Audit</title>
          <description>Find and audit visitor group usage across content, access rights, and properties.</description>
        </personalizationaudit>
        <audiencemanager>
          <title>Audience Manager</title>
          <description>Manage and review visitor groups and audience segments.</description>
        </audiencemanager>
        <contenttyperecommendations>
          <title>Content Type Recommendations</title>
          <description>Get recommendations for content type improvements and consolidation.</description>
        </contenttyperecommendations>
        <bulkpropertyeditor>
          <title>Bulk Property Editor</title>
          <description>Edit properties across multiple content items at once.</description>
        </bulkpropertyeditor>
        <scheduledjobsgantt>
          <title>Scheduled Jobs Gantt</title>
          <description>Visualize scheduled job execution as a Gantt chart.</description>
        </scheduledjobsgantt>
        <activitytimeline>
          <title>Activity Timeline</title>
          <description>View a timeline of content changes and editorial activity.</description>
        </activitytimeline>
        <contentimporter>
          <title>Content Importer</title>
          <description>Import content from CSV, JSON, or Excel files.</description>
        </contentimporter>
        <cmsdoctor>
          <title>CMS Doctor</title>
          <description>Health checks and diagnostics for your CMS installation.</description>
        </cmsdoctor>
        <contentaudit>
          <title>Content Audit</title>
          <description>Audit content for quality, completeness, and best practices.</description>
        </contentaudit>
        <linkchecker>
          <title>Link Checker</title>
          <description>Find and report broken links across your site.</description>
        </linkchecker>
        <activeeditors>
          <title>Active Editors</title>
          <description>See who is currently editing content and collaborate in real time.</description>
        </activeeditors>
        <managechildren>
          <title>Manage Children</title>
          <description>Bulk manage child pages: sort, publish, unpublish, move, and delete.</description>
        </managechildren>
        <overview>
          <title>Overview</title>
          <description>Dashboard overview of all Editor Powertools features.</description>
        </overview>
        <languageaudit>
          <title>Language Audit</title>
          <description>Analyze language coverage, find missing translations, and manage translation priorities.</description>
        </languageaudit>
        <linkaudit>
          <title>Link Audit</title>
          <description>Find and fix broken internal and external links across your content.</description>
        </linkaudit>
        <visitorgrouptester>
          <title>Visitor Group Tester</title>
          <description>Floating toolbar to simulate visitor group membership and inspect editable content elements.</description>
        </visitorgrouptester>
        <contentstatistics>
          <title>Content Statistics</title>
          <description>Visual dashboard with charts showing content distribution, creation trends, staleness, and editor activity.</description>
        </contentstatistics>
        <securityaudit>
          <title>Security Audit</title>
          <description>Analyze content permissions, find overly permissive access rights, and explore who can access what.</description>
        </securityaudit>

        </errors>
        <warnings>
          <nonamecolumn>名前列がマッピングされていません</nonamecolumn>
        </warnings>
        <status>
          <running>実行中</running>
          <completed>完了</completed>
          <failed>失敗</failed>
        </status>
      </contentimporter>

      <!-- アナライザー -->
      <analyzers>
        <contenttypestatistics>コンテンツタイプ統計</contenttypestatistics>
        <personalization>パーソナライゼーション</personalization>
        <linkchecker>リンクチェッカー</linkchecker>
        <languageaudit>言語監査</languageaudit>
        <securityaudit>セキュリティ監査</securityaudit>
      </analyzers>

